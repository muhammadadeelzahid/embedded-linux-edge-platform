# ────────────────────────────────────────────────
# RAUC A/B Slot Boot Script for Raspberry Pi + U-Boot
# ────────────────────────────────────────────────

fdt addr ${fdt_addr} && fdt get value bootargs /chosen bootargs

if test ! -e @@BOOT_MEDIA@@ 0:1 uboot.env; then saveenv; fi;

# Initialize RAUC defaults on first boot
test -n "${BOOT_ORDER}" || setenv BOOT_ORDER "A B"
test -n "${BOOT_A_LEFT}" || setenv BOOT_A_LEFT 3
test -n "${BOOT_B_LEFT}" || setenv BOOT_B_LEFT 3
saveenv

# Slot selection loop
setenv raucslot
for BOOT_SLOT in "${BOOT_ORDER}"; do
    if test -z "${raucslot}"; then
        if test "x${BOOT_SLOT}" = "xA"; then
            if test ${BOOT_A_LEFT} -gt 0; then
                setexpr BOOT_A_LEFT ${BOOT_A_LEFT} - 1
                setenv raucslot A
                setenv rootpart 2
            fi
        elif test "x${BOOT_SLOT}" = "xB"; then
            if test ${BOOT_B_LEFT} -gt 0; then
                setexpr BOOT_B_LEFT ${BOOT_B_LEFT} - 1
                setenv raucslot B
                setenv rootpart 3
            fi
        fi
    fi
done

if test -z "${raucslot}"; then
    echo "## No bootable slot — resetting ##"
    setenv BOOT_A_LEFT 3
    setenv BOOT_B_LEFT 3
    saveenv
    reset
fi

saveenv
echo "## Booting slot ${raucslot} (partition ${rootpart}) ##"

setenv bootargs "${bootargs} root=/dev/mmcblk0p${rootpart} rootfstype=ext4 rootwait rauc.slot=${raucslot}"

fatload @@BOOT_MEDIA@@ 0:1 ${kernel_addr_r} @@KERNEL_IMAGETYPE@@
@@KERNEL_BOOTCMD@@ ${kernel_addr_r} - ${fdt_addr}
