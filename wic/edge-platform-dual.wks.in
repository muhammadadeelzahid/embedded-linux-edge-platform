# Boot partition — firmware, U-Boot, kernel, DTBs, boot.scr
part /boot --source bootimg-partition --ondisk mmcblk0 --fstype=vfat --label boot --active --align 4096 --size 100

# Root filesystem A (default active slot)
part / --source rootfs --ondisk mmcblk0 --fstype=ext4 --label rootfsA --align 4096 --size 512

# Root filesystem B (initially empty, populated via dd from Linux)
part --ondisk mmcblk0 --fstype=ext4 --label rootfsB --align 4096 --size 512
